# Gerpain app — copy to apps/gerpain/.env.local

# Optional: force domain table truncate on seed (default: truncate only on localhost)
# SEED_TRUNCATE_DOMAIN=true

DATABASE_URL=postgresql://gerpain:gerpain@localhost:5432/gerpain_dev

BETTER_AUTH_SECRET=dev-only-change-me-before-production!!
BETTER_AUTH_URL=http://localhost:3000

VITE_APP_NAME=Gerpain
