# Local development — copy to .env at repo root (and apps/gerpain/.env.local for the app)

# Native Postgres (Homebrew / local install) — run: bun run db:init
DATABASE_URL=postgresql://gerpain:gerpain@localhost:5432/gerpain_dev

# Docker Postgres (port 5433 to avoid clashing with a local server) — run: bun run db:up
# DATABASE_URL=postgresql://gerpain:gerpain@localhost:5433/gerpain_dev

BETTER_AUTH_SECRET=dev-only-change-me-before-production!!
BETTER_AUTH_URL=http://localhost:3000

VITE_APP_NAME=Gerpain
